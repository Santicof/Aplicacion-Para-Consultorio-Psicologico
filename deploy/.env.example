# ==========================================
# Variables de entorno para producción
# Copiar como .env y completar los valores
# ==========================================

# Base de datos PostgreSQL
DB_USER=postgres
DB_PASSWORD=TU_PASSWORD_SEGURA_AQUI

# Google Calendar (copiar de Railway)
GOOGLE_CALENDAR_ENABLED=true
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-client-secret
GOOGLE_CALENDAR_REDIRECT_URI=http://TU_IP_O_DOMINIO/oauth2callback

# Dominio (cambiar cuando tengas dominio propio)
DOMAIN=TU_IP_O_DOMINIO
